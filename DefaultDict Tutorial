# Enter your code here. Read input from STDIN. Print output to STDOUT

#Import collections library and invoque the defaultdict
from collections import defaultdict

#read the integer n, m and store them.
n, m = map(int, input().split())

#initialize the default dictionaire
positions = defaultdict(list)

# This for loop read the input = key and find the 
#indices places in which the key value appear in 
#input list and store them as values in the defaultdict
#Example = {'a': [1,2,4]}
# Read Group A
for i in range(1, n + 1):
    word = input()
    positions[word].append(i)

#the operator ( * ) in *positions[word] print the list in separated
#space
#The for loop read the input and find it in the default dictionary
#and print the position indices.
#if it does not find the input it write -1
# Read Group B
for _ in range(m):
    word = input()

    if word in positions:
        print(*positions[word])
    else:
        print(-1)
