def print_formatted(number):
    # your code goes here
    
    #Determine the variable width which is the length of the binary 
    #number which we removed the ob at the begining
    width = len(bin(number)[2:])

    for i in range(1, number + 1):
        
        #convert the number to decimal, Octal, Hexadecimal, Binary

        decimal = str(i)
        octal = oct(i)[2:]
        hexadecimal = hex(i)[2:].upper()
        binary = bin(i)[2:]

        print(
            
        #adjust right the number so it will not collide and with
        #1 space in the middle. 
            decimal.rjust(width),
            octal.rjust(width),
            hexadecimal.rjust(width),
            binary.rjust(width)
        )
