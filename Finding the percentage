if __name__ == '__main__':
    n = int(input())
    student_marks = {}
    for _ in range(n):
        name, *line = input().split()
        scores = list(map(float, line))
        student_marks[name] = scores
    query_name = input()
    
    #to acces the list of scores : student_marks[query_name]
    #average is the sum of the scores divided by the lenght of the list of scores
    average = sum(student_marks[query_name]) / len(student_marks[query_name])

    #Print the average using an f string and using 2 decimal places
    print(f"{average:.2f}")
