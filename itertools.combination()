# Enter your code here. Read input from STDIN. Print output to STDOUT

#import the library itertools and invoque the combination function
from itertools import combinations

#read the 2 strings input and store them in S, k
S , k = input().split()

#For this remaining lines we will use a nested for loop
#we need all the combination from 1 to k included (k+1 in range)
#The first loop is to define the number of iterable ( 1 to k)
#the second for loop take the character from the combination function
#using the sorted string S and range that we defined in the first 
#for loop
#The last line is just to print the joint combination
for i in range(1 , int(k) +1):
    for combination in combinations(sorted(S), i):
        print("".join(combination))
